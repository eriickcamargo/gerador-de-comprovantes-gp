# Token do seu bot (obtido no @BotFather do Telegram)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Chave da API do Google Gemini (aistudio.google.com/app/apikey)
GEMINI_API_KEY=sua_chave_aqui

# Seu user ID do Telegram (use @userinfobot para descobrir o número)
# Separe múltiplos IDs com vírgula: 123456,654321
ALLOWED_USER_IDS=seu_user_id_aqui
